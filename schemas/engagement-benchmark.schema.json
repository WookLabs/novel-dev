{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://novel-dev.org/schemas/engagement-benchmark.schema.json",
  "title": "Engagement Benchmark Samples",
  "description": "Labeled chapter/manuscript benchmark samples used to measure engagement evaluator false positives, false negatives, issue detection, and genre/route coverage.",
  "type": "object",
  "required": ["samples"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "required_genres": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "maxItems": 40,
      "uniqueItems": true
    },
    "required_routes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["interest", "suspense", "beauty", "amusement", "genre-delight", "next-click"]
      },
      "maxItems": 6,
      "uniqueItems": true
    },
    "required_issue_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      },
      "maxItems": 100,
      "uniqueItems": true,
      "description": "Expected engagement issue codes that must have known-bad labeled samples before gate tuning is considered ready."
    },
    "required_positive_quality_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "signature-scene-image",
          "character-appeal-signature",
          "protagonist-agency",
          "choice-cost-tradeoff",
          "choice-cost-lock",
          "tactical-adaptation",
          "payoff-delight",
          "genre-delight",
          "next-click-compulsion",
          "narrative-transportation",
          "dialogue-subtext-turn",
          "causal-chain"
        ]
      },
      "maxItems": 20,
      "uniqueItems": true,
      "description": "Positive high-point qualities that must have known-good labeled samples before gate tuning is considered ready."
    },
    "minimum_samples_per_required_issue_code": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum labeled and usable known-bad samples required per required issue code."
    },
    "minimum_samples_per_required_positive_quality_code": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum labeled and usable known-good samples required per required positive high-point quality code."
    },
    "required_series_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Minimum consecutive chapter benchmark run required per required genre."
    },
    "required_positive_series_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Minimum consecutive known-good chapter benchmark run required per required genre."
    },
    "minimum_holdout_samples": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum reserved holdout samples required before engagement gate tuning is considered ready."
    },
    "minimum_usable_holdout_samples": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum passing reserved holdout samples required before engagement gate tuning is considered ready."
    },
    "minimum_failing_holdout_samples": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum known-bad reserved holdout samples required to catch fun false positives."
    },
    "minimum_usable_failing_holdout_samples": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum passing known-bad reserved holdout samples required before engagement gate tuning is considered ready."
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": ["id", "chapter", "expected_passed"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "label": {
            "type": "string",
            "maxLength": 200
          },
          "genre": {
            "type": "string",
            "maxLength": 80
          },
          "routes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["interest", "suspense", "beauty", "amusement", "genre-delight", "next-click"]
            },
            "maxItems": 6,
            "uniqueItems": true
          },
          "positive_quality_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "signature-scene-image",
                "character-appeal-signature",
                "protagonist-agency",
                "choice-cost-tradeoff",
                "choice-cost-lock",
                "tactical-adaptation",
                "payoff-delight",
                "genre-delight",
                "next-click-compulsion",
                "narrative-transportation",
                "dialogue-subtext-turn",
                "causal-chain"
              ]
            },
            "maxItems": 20,
            "uniqueItems": true,
            "description": "Positive high-point qualities evidenced by a known-good sample."
          },
          "chapter": {
            "type": "integer",
            "minimum": 1
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "calibration_split": {
            "type": "string",
            "enum": ["calibration", "validation", "holdout"],
            "description": "Reserved split for gate calibration. Holdout samples must not be used to tune thresholds."
          },
          "manuscript": {
            "type": "string",
            "description": "Optional inline manuscript override. If omitted, the CLI reads chapters/chapter_NNN.md."
          },
          "manuscript_path": {
            "type": "string",
            "description": "Optional project-relative or absolute manuscript override path."
          },
          "expected_passed": {
            "type": "boolean"
          },
          "expected_issue_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "maxItems": 100
          },
          "forbidden_issue_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "maxItems": 100
          },
          "expected_min_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "expected_max_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
