{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "team-state.schema.json",
  "title": "Team Execution State",
  "description": "팀 실행 인스턴스 런타임 상태 추적",
  "type": "object",
  "required": ["team_id", "team_definition", "status", "members", "workflow_progress"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "team_id": {
      "type": "string",
      "pattern": "^(?:team|novel-team)_[a-z0-9-]+_\\d{8}_\\d{6}$",
      "description": "팀 실행 인스턴스 고유 ID (예: team_verification-team_20260217_143000 또는 novel-team_verification-team_20260217_143000)"
    },
    "team_definition": {
      "type": "string",
      "description": "참조하는 팀 정의 파일명 (예: verification-team.team.json)"
    },
    "status": {
      "type": "string",
      "enum": ["initializing", "running", "completed", "failed", "cancelled"],
      "default": "initializing",
      "description": "팀 실행 상태"
    },
    "context": {
      "type": "object",
      "properties": {
        "novel_id": {
          "type": "string",
          "description": "대상 소설 프로젝트 ID"
        },
        "chapter": {
          "type": "integer",
          "minimum": 1,
          "description": "대상 챕터 번호"
        },
        "target_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "대상 파일 경로 목록"
        },
        "args": {
          "type": "object",
          "additionalProperties": true,
          "description": "추가 실행 인자"
        }
      },
      "description": "실행 컨텍스트"
    },
    "context_manifest": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/contextManifestEntry"
      },
      "description": "품질 게이트 팀이 실제로 읽은 파일, 상태, 이슈, 지시, task output의 freshness와 사용처를 기록한다"
    },
    "members": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/memberState"
      },
      "description": "팀원 실행 상태 목록"
    },
    "workflow_progress": {
      "type": "object",
      "required": ["total_steps", "completed_steps", "current_step"],
      "properties": {
        "total_steps": {
          "type": "integer",
          "minimum": 1,
          "description": "전체 단계 수"
        },
        "completed_steps": {
          "type": "integer",
          "minimum": 0,
          "description": "완료된 단계 수"
        },
        "current_step": {
          "type": "string",
          "description": "현재 진행 중인 단계 이름"
        }
      },
      "description": "워크플로우 진행 상태"
    },
    "quality_gate": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "results": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/gateResult"
          },
          "description": "에이전트별 품질 게이트 결과"
        },
        "overall_pass": {
          "type": "boolean",
          "description": "전체 품질 게이트 통과 여부"
        },
        "composite_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "가중 종합 점수"
        }
      },
      "description": "품질 게이트 결과"
    },
    "validation_conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/validationConflict"
      },
      "description": "검증자 간 PASS/FAIL, 심각도, 지시, 근거 이견을 보존하고 최종 판정 전 해결 여부를 기록"
    },
    "handoff_contracts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/handoffContract"
      },
      "description": "에이전트 또는 workflow step 간 전달되는 산출물, 필수 payload, acceptance check, 손실 위험을 기록"
    },
    "execution_trace": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/traceEvent"
      },
      "description": "팀 실행 재현과 실패 귀속을 위한 단계별 trace 이벤트"
    },
    "failure_attribution": {
      "$ref": "#/definitions/failureAttribution",
      "description": "실패 또는 품질 게이트 차단 시 원인 에이전트와 결정적 단계를 기록"
    },
    "recovery_plan": {
      "$ref": "#/definitions/recoveryPlan",
      "description": "실패 귀속 이후 재실행할 단계, 적용할 개입, 성공 기준, 검증 명령을 기록"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "팀 실행 시작 시간"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "팀 실행 완료 시간"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "마지막 상태 업데이트 시간"
    },
    "last_error": {
      "type": "string",
      "description": "마지막 에러 메시지",
      "maxLength": 1000
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["quality_gate"],
        "properties": {
          "quality_gate": {
            "required": ["enabled"],
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      },
      "then": {
        "required": ["context_manifest"]
      }
    },
    {
      "if": {
        "required": ["execution_trace"],
        "properties": {
          "execution_trace": {
            "contains": {
              "type": "object",
              "required": ["event_type"],
              "properties": {
                "event_type": { "const": "handoff" }
              }
            }
          }
        }
      },
      "then": {
        "required": ["handoff_contracts"]
      }
    }
  ],
  "definitions": {
    "contextManifestEntry": {
      "type": "object",
      "required": ["ref", "source_type", "loaded_at", "status", "required", "used_by"],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "파일 경로, task output, issue, directive, state ref 등 재확인 가능한 컨텍스트 참조"
        },
        "source_type": {
          "type": "string",
          "enum": ["file", "glob", "task_output", "issue", "directive", "schema", "state", "external"],
          "description": "컨텍스트 출처 유형"
        },
        "loaded_at": {
          "type": "string",
          "format": "date-time",
          "description": "오케스트레이터가 이 컨텍스트를 읽거나 확인한 시간"
        },
        "status": {
          "type": "string",
          "enum": ["loaded", "missing", "stale", "superseded", "not_applicable"],
          "description": "품질 게이트 판정에 사용할 수 있는 최신 컨텍스트인지 여부"
        },
        "required": {
          "type": "boolean",
          "description": "true이면 missing/stale/superseded 상태가 최종 PASS를 차단한다"
        },
        "used_by": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "이 컨텍스트를 입력으로 받은 agent, workflow step, gate 이름"
        },
        "checksum": {
          "type": "string",
          "description": "가능하면 파일 내용 또는 task output의 해시"
        },
        "mtime": {
          "type": "string",
          "format": "date-time",
          "description": "파일 기반 컨텍스트의 마지막 수정 시간"
        },
        "version": {
          "type": "string",
          "description": "chapter version, task version, state revision 등 비교 가능한 버전"
        },
        "freshness_checked_at": {
          "type": "string",
          "format": "date-time",
          "description": "stale 여부를 마지막으로 확인한 시간"
        },
        "stale_reason": {
          "type": "string",
          "description": "missing, stale, superseded 판정의 구체적 이유"
        },
        "blocking": {
          "type": "boolean",
          "description": "true이면 이 항목만으로도 PASS 금지"
        },
        "notes": {
          "type": "string",
          "description": "컨텍스트 사용 또는 freshness 판단에 대한 보충 설명"
        }
      },
      "additionalProperties": false
    },
    "memberState": {
      "type": "object",
      "required": ["agent", "status"],
      "properties": {
        "agent": {
          "type": "string",
          "description": "에이전트 이름"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "skipped"],
          "default": "pending",
          "description": "에이전트 실행 상태"
        },
        "task_id": {
          "type": "string",
          "description": "할당된 TaskCreate ID"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "result": {
          "type": "object",
          "additionalProperties": true,
          "description": "에이전트 실행 결과 (JSON)"
        },
        "error": {
          "type": "string",
          "description": "실패 시 에러 메시지",
          "maxLength": 500
        }
      }
    },
    "gateResult": {
      "type": "object",
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "pass": {
          "type": "boolean"
        },
        "verdict": {
          "type": "string"
        }
      }
    },
    "traceEvent": {
      "type": "object",
      "required": ["trace_event_id", "step_id", "step_name", "agent", "event_type", "timestamp", "input_refs", "output_refs", "status"],
      "properties": {
        "trace_event_id": {
          "type": "string",
          "description": "trace 내에서 참조 가능한 이벤트 ID"
        },
        "step_id": {
          "type": "string",
          "description": "팀 workflow step 식별자"
        },
        "step_name": {
          "type": "string",
          "description": "팀 workflow step 이름"
        },
        "agent": {
          "type": "string",
          "description": "이 이벤트를 생성한 에이전트 또는 orchestrator"
        },
        "event_type": {
          "type": "string",
          "enum": ["dispatch", "handoff", "agent_result", "validator_issue", "retry", "block", "error"],
          "description": "trace 이벤트 유형"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "blocked", "skipped"]
        },
        "input_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이 단계가 읽은 파일, 이전 출력, issue, directive 참조"
        },
        "output_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이 단계가 생성한 파일, 결과, issue, directive 참조"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "선행 trace_event_id 목록"
        },
        "issue_codes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이벤트와 연결된 validator issue code 목록"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "판정 또는 실패 귀속에 사용한 증거 스니펫"
        },
        "directive": {
          "type": "string",
          "description": "해당 이벤트에서 나온 수정 지시"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "verdict": {
          "type": "string"
        }
      }
    },
    "validationConflict": {
      "type": "object",
      "required": [
        "conflict_id",
        "conflict_type",
        "agents",
        "severity",
        "issue_codes",
        "trace_event_ids",
        "status",
        "minority_position",
        "resolution",
        "blocks_pass",
        "rationale"
      ],
      "properties": {
        "conflict_id": {
          "type": "string",
          "description": "validation_conflicts 안에서 참조 가능한 이견 ID"
        },
        "conflict_type": {
          "type": "string",
          "enum": ["pass_fail_split", "severity_disagreement", "directive_conflict", "evidence_conflict", "score_spread", "missing_evidence"],
          "description": "검증자 이견 유형"
        },
        "agents": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" },
          "description": "이견에 관여한 검증 에이전트 목록"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "major", "minor", "informational"],
          "description": "이견 자체의 처리 우선순위"
        },
        "issue_codes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이견과 연결된 issue code 목록. 점수 편차만 있는 경우 비울 수 있음"
        },
        "trace_event_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "이견을 만든 validator issue, agent result, quality gate trace_event_id 목록"
        },
        "status": {
          "type": "string",
          "enum": ["unresolved", "resolved", "blocked", "escalated", "not_applicable"],
          "description": "이견 해결 상태"
        },
        "minority_position": {
          "type": "string",
          "description": "평균 점수나 다수 의견에 묻힐 수 있는 소수 검증자 의견"
        },
        "winning_decision": {
          "type": "string",
          "description": "최종 판정에 반영한 결정. resolved일 때 왜 이 결정을 채택했는지 resolution에 근거를 남긴다"
        },
        "resolution": {
          "type": "string",
          "minLength": 1,
          "description": "이견을 해결하거나 차단한 방식"
        },
        "required_follow_up": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이견 해결을 위해 필요한 재검토, 재작성, 재검증 작업"
        },
        "blocks_pass": {
          "type": "boolean",
          "description": "true이면 status가 resolved가 되기 전까지 최종 PASS 금지"
        },
        "rationale": {
          "type": "string",
          "description": "이견의 위험도와 처리 결정을 설명하는 근거"
        }
      }
    },
    "handoffContract": {
      "type": "object",
      "required": [
        "handoff_id",
        "from_agent",
        "to_agent",
        "from_step",
        "to_step",
        "input_refs",
        "output_refs",
        "required_payloads",
        "acceptance_criteria",
        "status",
        "verified_by",
        "blocks_pass",
        "rationale"
      ],
      "properties": {
        "handoff_id": {
          "type": "string",
          "description": "handoff_contracts 안에서 참조 가능한 계약 ID"
        },
        "from_agent": {
          "type": "string",
          "description": "전달 산출물을 만든 agent 또는 orchestrator"
        },
        "to_agent": {
          "type": "string",
          "description": "전달 산출물을 입력으로 받는 agent 또는 workflow step"
        },
        "from_step": {
          "type": "string",
          "description": "전달이 시작된 workflow step_id"
        },
        "to_step": {
          "type": "string",
          "description": "전달을 소비하는 workflow step_id"
        },
        "trace_event_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이 handoff를 만들거나 검증한 trace_event_id 목록"
        },
        "input_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "handoff 생성에 사용된 파일, task output, issue, directive, state 참조"
        },
        "output_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "수신자가 반드시 입력으로 받아야 하는 산출물 참조"
        },
        "required_payloads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["kind", "ref", "status"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["issue", "directive", "evidence", "file", "state", "task_output", "schema", "score", "verdict", "context"],
                "description": "전달되어야 하는 payload 유형"
              },
              "ref": {
                "type": "string",
                "description": "issue code, directive ref, evidence ref, 파일 경로 등 재확인 가능한 참조"
              },
              "status": {
                "type": "string",
                "enum": ["present", "missing", "stale", "superseded", "weakened", "not_applicable"],
                "description": "수신 단계에 payload가 원래 강도와 최신성으로 전달됐는지 여부"
              },
              "source_trace_event_id": {
                "type": "string",
                "description": "payload를 처음 만든 trace_event_id"
              },
              "notes": {
                "type": "string",
                "description": "누락, 약화, 대체, 최신성 판단 근거"
              }
            },
            "additionalProperties": false
          },
          "description": "다음 agent에게 반드시 같은 강도로 넘어가야 하는 issue, directive, evidence, score, verdict, context 목록"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "handoff를 accepted로 볼 수 있는 검증 조건"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "blocked", "failed", "superseded", "not_applicable"],
          "description": "handoff 계약 검증 상태"
        },
        "loss_risks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "지시 약화, evidence 누락, score 무시, 파일 버전 혼동 등 전달 손실 위험"
        },
        "verified_by": {
          "type": "string",
          "description": "handoff acceptance를 검증한 agent 또는 orchestrator"
        },
        "blocks_pass": {
          "type": "boolean",
          "description": "true이면 accepted 전까지 최종 PASS 금지"
        },
        "rationale": {
          "type": "string",
          "description": "handoff 상태와 PASS 차단 여부를 설명하는 근거"
        }
      },
      "additionalProperties": false
    },
    "failureAttribution": {
      "type": "object",
      "required": ["status", "responsible_agent", "decisive_step", "failure_mode", "supporting_trace_events", "recoverability"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "suspected", "confirmed"],
          "description": "실패 귀속 확정 수준"
        },
        "responsible_agent": {
          "type": "string",
          "description": "원인 단계의 에이전트. 해당 없음이면 orchestrator 또는 none"
        },
        "decisive_step": {
          "type": "string",
          "description": "실패를 만든 결정적 workflow step_id"
        },
        "failure_mode": {
          "type": "string",
          "enum": ["not_applicable", "missing_evidence", "stale_context", "validator_conflict", "quality_gate_block", "agent_error", "handoff_loss", "policy_violation", "unknown"],
          "description": "실패 유형"
        },
        "supporting_trace_events": {
          "type": "array",
          "items": { "type": "string" },
          "description": "귀속 판단을 뒷받침하는 trace_event_id 목록"
        },
        "recoverability": {
          "type": "string",
