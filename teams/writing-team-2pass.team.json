{
  "$schema": "../schemas/team.schema.json",
  "schema_version": "1.0",
  "name": "writing-team-2pass",
  "display_name": "2-Pass 집필 팀",
  "description": "초안 작성 → 품질 진단 → 문체 수술 → 교정의 4단계 파이프라인으로 정밀 집필하는 팀",
  "category": "writing",
  "agents": [
    {
      "agent": "novelist",
      "role": "lead",
      "responsibility": "Pass 1: 챕터 초안 작성 (Scene-by-Scene Mode)",
      "model": "opus"
    },
    {
      "agent": "quality-oracle",
      "role": "validator",
      "responsibility": "품질 진단: 구절 수준 분석 + prose-surgeon용 수술 지시 생성",
      "model": "opus"
    },
    {
      "agent": "prose-surgeon",
      "role": "worker",
      "responsibility": "정밀 문장 수술: 진단 결과 기반 문장 수준 개선",
      "model": "opus"
    },
    {
      "agent": "proofreader",
      "role": "support",
      "responsibility": "최종 맞춤법/문법 교정",
      "model": "haiku"
    }
  ],
  "workflow": {
    "type": "pipeline",
    "steps": [
      {
        "name": "draft",
        "agents": ["novelist"],
        "execution": "sequential",
        "output": "완성된 챕터 초안"
      },
      {
        "name": "quality-diagnosis",
        "agents": ["quality-oracle"],
        "execution": "sequential",
        "depends_on": ["draft"],
        "output": "품질 진단 리포트 (점수 + 구체적 개선 지점)"
      },
      {
        "name": "prose-surgery",
        "agents": ["prose-surgeon"],
        "execution": "sequential",
        "depends_on": ["quality-diagnosis"],
        "output": "문체 개선된 챕터"
      },
      {
        "name": "final-proofread",
        "agents": ["proofreader"],
        "execution": "sequential",
        "depends_on": ["prose-surgery"],
        "output": "교정 완료된 최종 챕터"
      }
    ],
    "max_iterations": 2
  },
  "coordination": {
    "mode": "orchestrated",
    "lead": "novelist",
    "communication": "task-based"
  },
  "quality_gates": {
    "enabled": true,
    "consensus": "all_pass",
    "thresholds": {
      "quality-oracle": 80
    },
    "issue_policy": {
      "preserve_issue_codes": true,
      "required_issue_fields": ["code", "severity", "source_agent", "evidence", "directive"],
      "merge_strategy": "dedupe_by_code_highest_severity",
      "severity_order": ["critical", "major", "minor"],
      "critical_blocks_pass": true,
      "directive_priority": "critical_first",
      "provenance_required": true,
      "critical_action": "retry",
      "retry_from_step": "draft"
    }
  },
  "cost_estimate": {
    "tokens_per_agent": 40000,
    "warning_message": "2-Pass 집필 팀은 novelist, quality-oracle, prose-surgeon, proofreader 4개 에이전트 파이프라인을 사용합니다. 약 160K 토큰이 소요될 수 있습니다."
  }
}
