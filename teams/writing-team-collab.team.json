{
  "$schema": "../schemas/team.schema.json",
  "schema_version": "1.0",
  "name": "writing-team-collab",
  "display_name": "캐릭터 협업 집필 팀",
  "description": "캐릭터 에이전트들과 서술자가 collaborative 워크플로우로 함께 집필하는 팀 (성인 장면 리라이트 없음)",
  "category": "writing",
  "agents": [
    {
      "agent": "narrator",
      "role": "lead",
      "responsibility": "장면 브리핑, 캐릭터 출력 통합, 산문 직조, 최종 확정",
      "model": "opus"
    },
    {
      "agent": "characters/*",
      "role": "worker",
      "responsibility": "대사, 내면 묘사, 감정 반응, OOC 검토",
      "resolve": "from_scene_cast"
    },
    {
      "agent": "extras",
      "role": "worker",
      "responsibility": "에이전트 파일 없는 minor/cameo 캐릭터의 대사, 행동 생성",
      "model": "sonnet"
    },
    {
      "agent": "proofreader",
      "role": "support",
      "responsibility": "최종 맞춤법/문법 교정",
      "model": "haiku"
    },
    {
      "agent": "summarizer",
      "role": "support",
      "responsibility": "완성된 챕터 요약 생성 (후속 챕터 컨텍스트용)",
      "model": "haiku"
    }
  ],
  "workflow": {
    "type": "collaborative",
    "steps": [
      {
        "name": "collab-write",
        "agents": ["narrator", "characters/*"],
        "execution": "parallel",
        "output": "챕터 초고 (chapters/chapter_XXX.md)"
      },
      {
        "name": "quality-gate-draft",
        "agents": [],
        "execution": "sequential",
        "depends_on": ["collab-write"],
        "output": "품질 게이트 검사 결과",
        "type": "orchestrator_action",
        "action": "quality-gate",
        "_comment": "team-orchestrator가 scripts/quality-gate.mjs를 실행하여 초고 품질을 검증합니다. 기본 모드: strict."
      },
      {
        "name": "proofread",
        "agents": ["proofreader"],
        "execution": "sequential",
        "depends_on": ["quality-gate-draft"],
        "output": "교정된 챕터"
      },
      {
        "name": "summarize",
        "agents": ["summarizer"],
        "execution": "sequential",
        "depends_on": ["proofread"],
        "output": "챕터 요약 (context/summaries/chapter_XXX_summary.md)"
      }
    ]
  },
  "coordination": {
    "mode": "orchestrated",
    "lead": "narrator",
    "communication": "message-based"
  },
  "quality_gates": {
    "enabled": true
  },
  "cost_estimate": {
    "tokens_per_agent": 30000,
    "warning_message": "캐릭터 협업 집필 팀은 narrator(opus) + 캐릭터 에이전트(opus/sonnet)를 포함하여 약 90K 토큰이 소요될 수 있습니다."
  }
}
